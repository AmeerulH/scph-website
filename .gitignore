# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files with secrets (never commit)
.env
.env.local
.env.*.local
.env*

# vercel
.vercel

# Unlighthouse (full-site Lighthouse reports — regenerate locally)
/unlighthouse

# typescript
*.tsbuildinfo
next-env.d.ts

# Google service account credentials — never commit
nodal-episode-484712-m8-2778260f58b0.json
*-service-account*.json

# Generated Drive inventories (large; may include internal paths — regenerate locally)
scripts/data/drive-inventory*.json

# Local scratch / large Drive JSON exports (e.g. tmp/workshop-drive.json from DRIVE_OUTPUT)
/tmp/
